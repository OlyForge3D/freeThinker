From 0000000000000000000000000000000000000003 Mon Sep 17 00:00:00 2001
From: Eryone X400 Migration <noreply@example.com>
Date: Thu, 15 May 2026 00:00:02 +0000
Subject: [PATCH 3/4] klippy: add legacy PLR hooks to virtual_sdcard

Legacy X400 behavior added two power-loss-recovery hooks:
- optional initial seek from `/tmp/pose` when selecting a file with `Z=...`
- replay `/tmp/plr.gcode` once on first read after seek

This remains as a temporary patch artifact. The long-term plan is to replace
it with an explicit `eryone_plr` extra and Moonraker integration.
---
 klippy/extras/virtual_sdcard.py | 30 ++++++++++++++++++++++++++++++
 1 file changed, 30 insertions(+)

diff --git a/klippy/extras/virtual_sdcard.py b/klippy/extras/virtual_sdcard.py
index 488b028..14dd9f9 100644
--- a/klippy/extras/virtual_sdcard.py
+++ b/klippy/extras/virtual_sdcard.py
@@ -10,6 +10,7 @@ VALID_GCODE_EXTS = ['gcode', 'g', 'gco']
 class VirtualSD:
     def __init__(self, config):
         self.printer = config.get_printer()
+        self.z_str = None
         self.printer.register_event_handler("klippy:shutdown",
                                             self.handle_shutdown)
         # sdcard state
@@ -173,6 +174,7 @@ class VirtualSD:
         flist = [f[0] for f in files]
         files_by_lower = { fname.lower(): fname for fname, fsize in files }
         fname = filename
+        gcmd.respond_raw("self.filename:%s" % filename)
         try:
             if fname not in flist:
                 fname = files_by_lower[fname.lower()]
@@ -188,6 +190,21 @@ class VirtualSD:
         gcmd.respond_raw("File selected")
         self.current_file = f
         self.file_position = 0
+        self.z_str = gcmd.get('Z', None)
+        if self.z_str:
+            try:
+                with open("/tmp/pose", 'r', encoding='utf-8') as file:
+                    for line_number, line in enumerate(file, 1):
+                        self.file_position = int(line)
+                        gcmd.respond_raw("self.file_position:%d" % self.file_position)
+                        break
+            except:
+                logging.exception("resume print fail,Unable to open file /tmp/pose")
+                raise gcmd.error("resume print fail,Unable to open file /tmp/pose")
+                                 
+                                 
+        gcmd.respond_raw("load file,position:%d" % self.file_position)
+        #self.file_position = 0
         self.file_size = fsize
         pause_resume = self.printer.lookup_object('pause_resume')
         if pause_resume.is_paused:
@@ -218,6 +235,13 @@ class VirtualSD:
         self.next_file_position = pos
     def is_cmd_from_sd(self):
         return self.cmd_from_sd
+
+
+    def run_plr(self):
+        self.gcode.respond_raw("run_plr")
+        with open("/tmp/plr.gcode", 'r', encoding='utf-8') as file:
+            for line_number, line in enumerate(file, 1):
+                self.gcode.run_script_from_command(line)
     # Background work timer
     def work_handler(self, eventtime):
         logging.info("Starting SD card print (position %d)", self.file_position)
@@ -233,11 +257,17 @@ class VirtualSD:
         partial_input = ""
         lines = []
         error_message = None
+        
+
         while not self.must_pause_work:
             if not lines:
                 # Read more data
                 try:
                     data = self.current_file.read(8192)
+                    #luojin
+                    if self.file_position>0 and self.z_str:
+                        self.z_str = None
+                        self.run_plr()
                 except:
                     logging.exception("virtual_sdcard read")
                     break
