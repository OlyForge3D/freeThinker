# X400 RP2040 CAN toolhead profile (default).
#
# Derived from rockybeachradio/x400-software-pack_mks-soc:
#   - mcu-bootloader-configurations/rp2040_katapult_Bootloader_usb.config
#   - mcu-firmware-configurations/rp2040_klipper_firmware.config
#
# This assumes Katapult on the RP2040 and app firmware start at 0x10004000.

CONFIG_LOW_LEVEL_OPTIONS=y
CONFIG_MACH_RPXXXX=y
CONFIG_MACH_RP2040=y
CONFIG_HAVE_BOOTLOADER_REQUEST=y

# App start 0x10004000 (16KiB bootloader offset).
CONFIG_RPXXXX_FLASH_START_4000=y

# Build Klipper for CAN bus communication.
CONFIG_RPXXXX_CANBUS=y

# X400 toolhead CAN transceiver pins from discovered config.
CONFIG_RPXXXX_CANBUS_GPIO_RX=8
CONFIG_RPXXXX_CANBUS_GPIO_TX=9

CONFIG_CANBUS_FREQUENCY=1000000
