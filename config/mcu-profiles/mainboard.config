# X400 SKIPR STM32F407 mainboard profile (default).
#
# Derived from rockybeachradio/x400-software-pack_mks-soc:
#   - mcu-bootloader-configurations/stm32f407_katapult_bootloader.config
#   - mcu-firmware-configurations/stm32f407_klipper_firmware.config
#
# Important: this profile assumes Katapult is installed and app firmware starts
# at 0x08008000 (32KiB bootloader offset).
#
# If your board is still on the no-bootloader vendor path, use a profile with
# CONFIG_STM32_FLASH_START_0000 instead.

CONFIG_LOW_LEVEL_OPTIONS=y
CONFIG_MACH_STM32=y
CONFIG_MACH_STM32F407=y
CONFIG_CLOCK_FREQ=168000000
CONFIG_STM32_CLOCK_REF_8M=y
CONFIG_STM32_DFU_ROM_ADDRESS=0x1fff0000

# Klipper app start for Katapult on STM32F407.
CONFIG_STM32_FLASH_START_8000=y

# X400 mainboard CAN wiring from discovered config.
CONFIG_STM32_CANBUS_PB12_PB13=y
CONFIG_CANBUS_FREQUENCY=1000000

# Keep bootloader handoff available (needed for -r requests).
CONFIG_HAVE_BOOTLOADER_REQUEST=y
