# Copy to config/mcu-update.env and edit values for your printer.

# Path to your mainline Klipper checkout
KLIPPER_DIR="$HOME/klipper"

# Path to Katapult checkout (installed/updated by migration script)
KATAPULT_DIR="$HOME/katapult"

# CAN interface used by your host
CAN_IFACE="can0"

# Physical MCU UUIDs (unique per board)
# Leave empty to auto-read from ~/printer_data/config/canuid.cfg.
MAINBOARD_UUID=""
TOOLHEAD_UUID=""

# Optional overrides
# PROFILE_DIR="$PWD/config/mcu-firmware-configurations"
# OUTPUT_DIR="$PWD/out/mcu"
